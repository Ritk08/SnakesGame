import pygame
import random
import sys
import os
from pygame import mixer

# Initialize Pygame
# Set dummy drivers to avoid errors in headless environments like OnlineGDB
os.environ['SDL_VIDEODRIVER'] = 'dummy'
os.environ['SDL_AUDIODRIVER'] = 'dummy'

pygame.init()
mixer.init()
# Constants
WINDOW_WIDTH = 800
WINDOW_HEIGHT = 600
GRID_SIZE = 20
GRID_WIDTH = WINDOW_WIDTH // GRID_SIZE
GRID_HEIGHT = WINDOW_HEIGHT // GRID_SIZE

# Colors (Beautiful gradient theme)
BLACK = (0, 0, 0)
WHITE = (255, 255, 255)
GREEN = (0, 255, 0)
DARK_GREEN = (0, 200, 0)
RED = (255, 50, 50)
GOLD = (255, 215, 0)
BLUE = (100, 150, 255)
PURPLE = (200, 100, 255)

class SnakeGame:
    def __init__(self):
        self.screen = pygame.display.set_mode((WINDOW_WIDTH, WINDOW_HEIGHT))
        pygame.display.set_caption("🐍 Snake Game - Eat, Grow, Survive! 🐍")
        self.clock = pygame.time.Clock()
        self.font_large = pygame.font.Font(None, 74)
        self.font_medium = pygame.font.Font(None, 48)
        self.font_small = pygame.font.Font(None, 36)
        self.reset_game()
        
    def reset_game(self):
        """Reset game to initial state"""
        self.snake = [(GRID_WIDTH // 2, GRID_HEIGHT // 2)]
        self.direction = (1, 0)  # Right
        self.food = self.generate_food()
        self.score = 0
        self.high_score = self.load_high_score()
        self.game_over = False
        self.paused = False
        self.speed = 10
        
    def generate_food(self):
        """Generate random food position not on snake"""
        while True:
            food = (random.randint(0, GRID_WIDTH - 1), 
                   random.randint(0, GRID_HEIGHT - 1))
            if food not in self.snake:
                return food
                
    def load_high_score(self):
        """Load high score from file"""
        try:
            with open("highscore.txt", "r") as f:
                return int(f.read())
        except:
            return 0
            
    def save_high_score(self):
        """Save high score to file"""
        if self.score > self.high_score:
            self.high_score = self.score
            with open("highscore.txt", "w") as f:
                f.write(str(self.high_score))
                
    def handle_events(self):
        """Handle keyboard input"""
        for event in pygame.event.get():
            if event.type == pygame.QUIT:
                return False
                
            if event.type == pygame.KEYDOWN:
                if event.key == pygame.K_ESCAPE or event.key == pygame.K_q:
                    return False
                    
                if self.game_over:
                    if event.key == pygame.K_r or event.key == pygame.K_RETURN:
                        self.reset_game()
                    continue
                    
                if event.key == pygame.K_SPACE:
                    self.paused = not self.paused
                    continue
                    
                # Direction control (prevent reverse)
                new_dir = self.direction
                if event.key in (pygame.K_UP, pygame.K_w) and self.direction != (0, 1):
                    new_dir = (0, -1)
                elif event.key in (pygame.K_DOWN, pygame.K_s) and self.direction != (0, -1):
                    new_dir = (0, 1)
                elif event.key in (pygame.K_LEFT, pygame.K_a) and self.direction != (1, 0):
                    new_dir = (-1, 0)
                elif event.key in (pygame.K_RIGHT, pygame.K_d) and self.direction != (-1, 0):
                    new_dir = (1, 0)
                    
                self.direction = new_dir
                
        return True
        
    def update(self):
        """Update game logic"""
        if self.paused or self.game_over:
            return
            
        # Move snake
        head = self.snake[0]
        new_head = (head[0] + self.direction[0], head[1] + self.direction[1])
        
        # Check wall collision
        if (new_head[0] < 0 or new_head[0] >= GRID_WIDTH or 
            new_head[1] < 0 or new_head[1] >= GRID_HEIGHT):
            self.game_over = True
            self.save_high_score()
            return
            
        # Check self collision
        if new_head in self.snake:
            self.game_over = True
            self.save_high_score()
            return
            
        self.snake.insert(0, new_head)
        
        # Check food collision
        if new_head == self.food:
            self.score += 10
            self.food = self.generate_food()
            self.speed = max(10, self.speed + 0.2)  # Increase speed
        else:
            self.snake.pop()
            
    def draw_gradient_rect(self, surface, color1, color2, rect):
        """Draw gradient rectangle"""
        for y in range(rect.height):
            ratio = y / rect.height
            r = int(color1[0] * (1 - ratio) + color2[0] * ratio)
            g = int(color1[1] * (1 - ratio) + color2[1] * ratio)
            b = int(color1[2] * (1 - ratio) + color2[2] * ratio)
            pygame.draw.line(surface, (r, g, b), 
                           (rect.x, rect.y + y), 
                           (rect.x + rect.width, rect.y + y))
            
    def draw(self):
        """Draw everything"""
        # Background gradient
        overlay = pygame.Surface((WINDOW_WIDTH, WINDOW_HEIGHT))
        overlay.set_alpha(50)
        pygame.draw.rect(overlay, BLUE, (0, 0, WINDOW_WIDTH, WINDOW_HEIGHT))
        self.screen.blit(overlay, (0, 0))
        
        # Draw grid
        for x in range(0, WINDOW_WIDTH, GRID_SIZE):
            pygame.draw.line(self.screen, (50, 50, 50), (x, 0), (x, WINDOW_HEIGHT))
        for y in range(0, WINDOW_HEIGHT, GRID_SIZE):
            pygame.draw.line(self.screen, (50, 50, 50), (0, y), (WINDOW_WIDTH, y))
            
        # Draw snake with gradient
        for i, segment in enumerate(self.snake):
            x, y = segment
            rect = pygame.Rect(x * GRID_SIZE + 2, y * GRID_SIZE + 2, 
                             GRID_SIZE - 4, GRID_SIZE - 4)
            alpha = 255 - (i * 10 // max(1, len(self.snake)))
            color = tuple(min(255, c + 50) for c in DARK_GREEN)
            self.draw_gradient_rect(self.screen, GREEN, color, rect)
            
        # Draw food (shiny apple effect)
        fx, fy = self.food
        food_rect = pygame.Rect(fx * GRID_SIZE + 4, fy * GRID_SIZE + 4, 
                               GRID_SIZE - 8, GRID_SIZE - 8)
        pygame.draw.ellipse(self.screen, RED, food_rect)
        pygame.draw.ellipse(self.screen, GOLD, food_rect.inflate(-4, -4))
        
        # Draw UI
        score_text = self.font_medium.render(f"Score: {self.score}", True, WHITE)
        highscore_text = self.font_small.render(f"High Score: {self.high_score}", True, GOLD)
        speed_text = self.font_small.render(f"Speed: {self.speed:.1f}", True, PURPLE)
        
        self.screen.blit(score_text, (20, 20))
        self.screen.blit(highscore_text, (20, 70))
        self.screen.blit(speed_text, (20, 110))
        
        # Pause overlay
        if self.paused:
            pause_surf = pygame.Surface((WINDOW_WIDTH, WINDOW_HEIGHT))
            pause_surf.set_alpha(128)
            pause_surf.fill(BLACK)
            self.screen.blit(pause_surf, (0, 0))
            pause_text = self.font_large.render("PAUSED", True, WHITE)
            text_rect = pause_text.get_rect(center=(WINDOW_WIDTH//2, WINDOW_HEIGHT//2))
            self.screen.blit(pause_text, text_rect)
            
        # Game Over screen
        if self.game_over:
            game_over_surf = pygame.Surface((WINDOW_WIDTH, WINDOW_HEIGHT))
            game_over_surf.set_alpha(200)
            game_over_surf.fill(BLACK)
            self.screen.blit(game_over_surf, (0, 0))
            
            title = self.font_large.render("GAME OVER", True, RED)
            score_final = self.font_medium.render(f"Final Score: {self.score}", True, WHITE)
            restart = self.font_small.render("Press R or ENTER to Restart", True, GOLD)
            quit_text = self.font_small.render("ESC or Q to Quit", True, WHITE)
            
            title_rect = title.get_rect(center=(WINDOW_WIDTH//2, WINDOW_HEIGHT//2 - 80))
            score_rect = score_final.get_rect(center=(WINDOW_WIDTH//2, WINDOW_HEIGHT//2 - 20))
            restart_rect = restart.get_rect(center=(WINDOW_WIDTH//2, WINDOW_HEIGHT//2 + 40))
            quit_rect = quit_text.get_rect(center=(WINDOW_WIDTH//2, WINDOW_HEIGHT//2 + 80))
            
            self.screen.blit(title, title_rect)
            self.screen.blit(score_final, score_rect)
            self.screen.blit(restart, restart_rect)
            self.screen.blit(quit_text, quit_rect)
            
        pygame.display.flip()
        
    def run(self):
        """Main game loop"""
        running = True
        while running:
            running = self.handle_events()
            self.update()
            self.draw()
            self.clock.tick(self.speed)
            
        pygame.quit()
        sys.exit()

# Run the game! 🐍
if __name__ == "__main__":
    game = SnakeGame()
    game.run()
